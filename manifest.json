{
  "manifest_version": 3,
  "name": "SilentShield",
  "version": "6.1",
  "description": "AI-powered real-time cyberbullying protection on Reddit and X.",

  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "192": "icons/icon-192.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "32":  "icons/icon-32.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://*.reddit.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "libs/transformers.min.js",
        "libs/ort-wasm.wasm",
        "libs/ort-wasm-simd.wasm",
        "libs/ort-wasm-threaded.wasm",
        "libs/ort-wasm-simd-threaded.wasm"
      ],
      "matches": [
        "*://*.reddit.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*"
      ]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "silentshield@teckathon",
      "strict_min_version": "109.0"
    }
  }
}
