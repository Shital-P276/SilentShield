{
  "manifest_version": 3,
  "name": "🛡️ SilentShield",
  "version": "1.2",
  "description": "AI Cyberbullying Protection Browser Extension",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "contextMenus", 
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SilentShield"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.reddit.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*",
        "https://*.google.com/search*",
        "https://*.duckduckgo.com/*"
      ],
      "js": [
        "content/content.js",
        "content/linkScanner.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ]
}