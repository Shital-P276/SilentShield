{
  "manifest_version": 3,
  "name": "🛡️ SilentShield AI Pro",
  "version": "2.0",
  "description": "AI Cyberbullying & Malicious Link Protection Browser Extension",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>",
    "*://*.reddit.com/*",
    "*://*.twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SilentShield AI Pro"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/linkScanner.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://huggingface.co https://cdn.jsdelivr.net https://raw.githubusercontent.com;"
  }
}